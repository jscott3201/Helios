{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Gemma4D TUI Keymap",
  "type": "object",
  "required": [
    "version",
    "bindings"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "bindings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "scope",
          "key",
          "action",
          "description"
        ],
        "properties": {
          "scope": {
            "type": "string"
          },
          "key": {
            "type": "string"
          },
          "action": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "destructive": {
            "type": "boolean",
            "default": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
